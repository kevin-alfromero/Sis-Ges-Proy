generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
    output = "/home/ubuntu/gestor_tareas/nextjs_space/node_modules/.prisma/client"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  role      String   @default("user") // "manager" or "user"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tasks     Task[]   @relation("AssignedTasks")
}

model Task {
  id          String   @id @default(cuid())
  title       String
  description String?
  status      String   @default("por_comenzar") // "por_comenzar", "pendiente_finalizacion", "completa"
  sector      String?
  assignedToId String?
  assignedTo  User?    @relation("AssignedTasks", fields: [assignedToId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
